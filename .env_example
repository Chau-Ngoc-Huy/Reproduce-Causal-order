# cp .env_example .env  &&  set -a; source .env; set +a

# Required
OPENAI_API_KEY=sk-your-key-here

# Optional — run_all_traces.sh overrides (defaults shown)
DATASETS="cancer earthquake survey asia child"
PW_MODEL=gpt-4o
PROMPT_TYPE=cot
SUBGRAPH_MODEL=gpt-4o-mini
EXPERT_MODEL=gpt-4o
DELAY=1
SKIP_EXISTING=1
RUN_PAIRWISE=1
RUN_TRIPLET=1
AUTO_YES=1
